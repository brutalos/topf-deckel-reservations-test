generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Order {
  id                   String  @id
  storeId              String
  wolt_delivery_id     String?
  wolt_tracking_id     String?
  status               String
  order_number         String
  customerName         String
  customerPhone        String
  customerAddress      String
  deliveryTime         String
  deliveryNote         String?
  noContact            Boolean
  amount               Float
  orderDetails         String   // Stored as JSON string
  promiseId            String
  eta                  Int?
  eta_iso              String?
  pickup_eta           Int?
  pickup_eta_iso       String?
  tracking_url         String?
  canCancel            Boolean  @default(true)
  stripePaymentId      String   @unique
  scheduledDropoffTime String?
  createdAt            String   // Stored as ISO string
}

model Meta {
  id    String @id @default("singleton")
  count Int    @default(999)
}

model Reservation {
  id              String  @id
  storeId         String
  guestName       String
  guestEmail      String
  guestPhone      String
  partySize       Int
  reservationDate String  // ISO date
  startTime       String  // ISO time
  durationMinutes Int     @default(60)
  status          String  // PENDING, CONFIRMED, SEATED, COMPLETED, NO_SHOW, CANCELLED
  notes           String?
  editToken       String  @unique
  createdAt       String  // ISO string
  updatedAt       String  // ISO string

  assignments     ReservationTableAssignment[]
  auditLogs       ReservationAuditLog[]
}

model ReservationTableAssignment {
  id            String      @id
  reservationId String
  tableId       String
  slotDateTime  String      // ISO date-time for each 15-minute block
  
  reservation   Reservation @relation(fields: [reservationId], references: [id])

  @@unique([tableId, slotDateTime])
}

model ReservationBlock {
  id           String  @id
  storeId      String
  tableId      String? // Optional: block specific table or entire store
  slotDateTime String  // ISO date-time
  reason       String?

  @@unique([tableId, slotDateTime])
}

model ReservationAuditLog {
  id            String      @id
  reservationId String
  action        String      // STATUS_CHANGE, EDITED, CANCELLED
  details       String
  timestamp     String      // ISO string
  
  reservation   Reservation @relation(fields: [reservationId], references: [id])
}
